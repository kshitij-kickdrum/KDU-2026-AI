OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=gpt-4o-mini
TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
AUDIO_SAMPLE_RATE=16000
AUDIO_SILENCE_THRESHOLD=500
AUDIO_SPEECH_MIN_DURATION_MS=300
AUDIO_SILENCE_MIN_DURATION_MS=700
SQLITE_DB_PATH=data/customer_billing.db
FAISS_INDEX_PATH=data/faiss_index.index
FAISS_METADATA_PATH=data/faiss_metadata.json
LOG_FILE_PATH=logs/session.ndjson
SQLITE_MAX_CONNECTIONS=5
FAISS_MAX_CONNECTIONS=10
QUEUE_TIMEOUT_SECONDS=5

