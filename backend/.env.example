# OpenRouter API keys (get from https://openrouter.ai/keys)
TEXT_MODEL_API_KEY=your-openrouter-key-for-hermes3
VISION_MODEL_API_KEY=your-openrouter-key-for-gemma3
CLASSIFIER_MODEL_API_KEY=your-openrouter-key-for-llama32

# Weather
WEATHER_API_KEY=your-openweathermap-api-key-here
USE_MOCK_WEATHER=true

# App
LOG_LEVEL=DEBUG
ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://[::1]:5173

# Agent
MAX_PARSER_RETRIES=2
MAX_AGENT_ITERATIONS=5
